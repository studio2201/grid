#!/bin/sh
# postinst script for grid
set -e

case "$1" in
    configure)
        # Create system user (nobody:users with UID/GID 99/100 to match Unraid layout)
        if ! getent group grid >/dev/null 2>&1; then
            addgroup --system --gid 100 grid 2>/dev/null || true
        fi
        if ! getent passwd grid >/dev/null 2>&1; then
            adduser --system --uid 99 --ingroup grid \
                --home /var/lib/grid \
                --no-create-home \
                --shell /usr/sbin/nologin \
                --gecos "Grid Kanban board service account" \
                grid 2>/dev/null || true
        fi

        # Create data directory
        mkdir -p /var/lib/grid
        chown grid:grid /var/lib/grid
        chmod 755 /var/lib/grid

        # Create default config file if missing
        if [ ! -f /etc/default/grid ]; then
            cat > /etc/default/grid << 'CFGEOF'
# Default configuration for Grid Kanban board
# Override any value by uncommenting and editing.
PORT=4405
SITE_TITLE=Grid Kanban board
TZ=UTC
CFGEOF
            chmod 644 /etc/default/grid
        fi

        echo "==============================================="
        echo "  Grid Kanban board installed successfully"
        echo "  Config:  /etc/default/grid"
        echo "  Data:    /var/lib/grid"
        echo "  Binary:  /usr/bin/grid"
        echo ""
        echo "  Start manually: grid"
        echo "==============================================="
        ;;
esac

#DEBHELPER#
exit 0
